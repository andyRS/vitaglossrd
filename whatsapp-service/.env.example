# ── VitaGloss WhatsApp Service ─────────────────────────────
# Copia este archivo como .env y completa los valores

# Puerto del servidor (default: 3002)
WA_PORT=3002

# Clave secreta para proteger los endpoints
WA_SECRET=vitagloss_wa_2026

# API Key de Google Gemini (gratis en https://aistudio.google.com/apikey)
# Si se deja vacío, el bot usará respuestas básicas sin IA
GEMINI_API_KEY=TU_API_KEY_AQUI
